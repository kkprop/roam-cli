{:paths ["src"]

 :tasks
 {:requires ([clojure.string :as str]
             [roam.protocol.roam :as protocol]
             [roam.core.read :as read]
             [roam.core.write :as write]
             [roam.core.search :as search]
             [roam.setup :as setup])

  ;; Read
  read {:doc "Read page or block: <graph> <page-or-uid>"
        :task (let [[g id] *command-line-args*]
                (if (and g id)
                  (read/read-cli g id)
                  (println "Usage: bb read <graph> <page-or-uid>")))}

  query {:doc "Datalog query: <graph> <query-string>"
         :task (let [[g & q] *command-line-args*]
                 (if (and g (seq q))
                   (read/query-cli g (str/join " " q))
                   (println "Usage: bb query <graph> \"[:find ...]\"")))}

  pull {:doc "Pull block by UID: <graph> <uid>"
        :task (let [[g uid] *command-line-args*]
                (if (and g uid)
                  (read/pull-cli g uid)
                  (println "Usage: bb pull <graph> <uid>")))}

  ;; Write
  write {:doc "Write: <graph> [--titled T] [--tree] [--to uid] <content-or-file>"
         :task (let [[g & args] *command-line-args*]
                 (if (and g (seq args))
                   (loop [remaining args, opts {}]
                     (if (empty? remaining)
                       (println "Usage: bb write <graph> [--titled T] [--tree] <content>")
                       (let [a (first remaining)]
                         (cond
                           (= a "--titled")
                           (recur (drop 2 remaining) (assoc opts :title (second remaining) :mode "titled"))
                           (= a "--tree")
                           (recur (rest remaining) (assoc opts :mode "tree"))
                           (= a "--to")
                           (recur (drop 2 remaining) (assoc opts :to (second remaining)))
                           :else
                           (apply write/write-cli g (str/join " " remaining) (mapcat identity opts))))))
                   (println "Usage: bb write <graph> [--titled T] [--tree] <content>")))}

  update {:doc "Update block: <graph> <uid> <new-content>"
          :task (let [[g uid & content] *command-line-args*]
                  (if (and g uid (seq content))
                    (write/update-cli g uid (str/join " " content))
                    (println "Usage: bb update <graph> <uid> \"new content\"")))}

  ;; Search
  search {:doc "Search blocks: <graph> <term>"
          :task (let [[g & terms] *command-line-args*]
                  (if (and g (seq terms))
                    (search/search-cli g (str/join " " terms))
                    (println "Usage: bb search <graph> \"term\"")))}

  pages {:doc "Search pages: <graph> <term>"
         :task (let [[g & terms] *command-line-args*]
                 (if (and g (seq terms))
                   (search/pages-cli g (str/join " " terms))
                   (println "Usage: bb pages <graph> \"term\"")))}

  ;; Utility
  setup {:doc "Interactive setup wizard — add Roam graph connection"
         :task (setup/setup-cli *command-line-args*)}

  graphs {:doc "List configured graphs"
          :task (setup/graphs-cli *command-line-args*)}

  test-connection {:doc "Test graph connection: <graph>"
                   :task (let [[g] *command-line-args*]
                           (if g
                             (protocol/test-connection g)
                             (println "Usage: bb test-connection <graph>")))}

  daily {:doc "Show today's daily page: <graph>"
         :task (let [[g] *command-line-args*]
                 (if g
                   (read/daily-cli g)
                   (println "Usage: bb daily <graph>")))}

  context {:doc "Show block in context (ancestor chain): <graph> <uid>"
           :task (let [[g uid] *command-line-args*]
                   (if (and g uid)
                     (read/context-cli g uid)
                     (println "Usage: bb context <graph> <uid>")))}

  build {:doc "Build standalone binary → dist/roam"
         :requires ([babashka.fs :as bfs] [babashka.process :as bp] [clojure.string :as bstr])
         :task (let [ver (if (bfs/exists? "VERSION") (bstr/trim (slurp "VERSION")) "dev")
                     jar "dist/roam.jar"
                     bin "dist/roam"
                     bb-bin (bstr/trim (:out (bp/shell {:out :string} "which" "bb")))]
                 (bfs/create-dirs "dist")
                 (println (str "📦 Building uberjar (v" ver ")..."))
                 (bp/shell "bb" "uberjar" jar "-m" "roam.main")
                 (println "🔗 Creating standalone binary...")
                 (bp/shell "bash" "-c" (str "cat " bb-bin " " jar " > " bin))
                 (bp/shell "chmod" "+x" bin)
                 (bfs/delete-if-exists jar)
                 (println (str "✅ dist/roam built (" (quot (bfs/size bin) (* 1024 1024)) "MB, v" ver ")")))}

  release {:doc "Bump version, build, git tag, GitHub release with binary"
           :requires ([babashka.fs :as bfs] [babashka.process :as bp]
                      [clojure.string :as bstr] [cheshire.core :as json])
           :task
           (let [old-ver (bstr/trim (slurp "VERSION"))
                 parts (bstr/split old-ver (re-pattern "[.]"))
                 new-ver (str (nth parts 0) "." (nth parts 1) "." (inc (Integer/parseInt (nth parts 2))))
                 tag (str "v" new-ver)
                 gh-token (bstr/trim (slurp (str (System/getProperty "user.home") "/.config/mata/github-token")))
                 repo "kkprop/roam-cli"]
             (spit "VERSION" (str new-ver "\n"))
             (println (str "📦 " old-ver " → " new-ver))
             (bp/shell "git" "add" "-A")
             (bp/shell "git" "commit" "-m" (str "release: " tag))
             (bp/shell "git" "push" "origin" "main")
             (bp/shell "git" "tag" tag)
             (bp/shell "git" "push" "origin" tag)
             (bp/shell "bb" "build")
             (let [resp (json/parse-string
                          (:out (bp/shell {:out :string} "curl" "-s" "-X" "POST"
                                          (str "https://api.github.com/repos/" repo "/releases")
                                          "-H" (str "Authorization: token " gh-token)
                                          "-H" "Content-Type: application/json"
                                          "-d" (json/generate-string {:tag_name tag :name tag
                                                                      :body (str "roam-cli " new-ver)})))
                          true)
                   upload-url (bstr/replace (str (:upload_url resp)) "{?name,label}" "")]
               (when-not (:id resp)
                 (println "❌ Release creation failed")
                 (println resp)
                 (System/exit 1))
               (println "📤 Uploading binary...")
               (bp/shell "curl" "-s" "-X" "POST"
                         (str upload-url "?name=roam-macos-arm64")
                         "-H" (str "Authorization: token " gh-token)
                         "-H" "Content-Type: application/octet-stream"
                         "--data-binary" "@dist/roam")
               (println (str "✅ Released " tag " → " (:html_url resp)))))}}}

